{
  "manifest_version": 3,
  "name": "LinkSnap",
  "version": "1.0.0",
  "description": "Create beautiful, shareable screenshots of LinkedIn posts.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.licdn.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*"
      ],
      "js": [
        "libs/html-to-image.min.js",
        "utils/constants.js",
        "utils/storage.js",
        "utils/export.js",
        "modal/modal.js",
        "content/extractor.js",
        "content/injector.js"
      ],
      "css": [
        "content/content.css",
        "modal/modal.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "themes/*"
      ],
      "matches": [
        "https://*.linkedin.com/*"
      ]
    }
  ]
}
